# Copy this file to e.g. workspaces/editor-betterco-claude.env and fill in real values.
# The widget authenticates with these credentials (REST key+secret AND user email/password).
# REST is used for customer/case/process/document reads & writes; the User-API registry
# path is used only for the enriched NorthData/company.info customer creation (step 3).

BETTERCO_BASE_URL=https://editor.betterco.ai/bcapi
BETTERCO_API_KEY=
BETTERCO_API_SECRET=
BETTERCO_WORKSPACE_ID=
BETTERCO_ORG_ID=
BETTERCO_USER_EMAIL=
BETTERCO_USER_PASSWORD=
